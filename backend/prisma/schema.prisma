generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model approval_history {
  id                 Int                 @id @default(autoincrement())
  leave_id           Int?
  approved_by        Int?
  action             String              @db.VarChar(50)
  remarks            String?
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  users              users?              @relation(fields: [approved_by], references: [id], onUpdate: NoAction)
  leave_applications leave_applications? @relation(fields: [leave_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model asset_allocations {
  id                Int                @id @default(autoincrement())
  asset_id          Int?
  employee_id       Int?
  allocated_by      Int?
  allocated_date    DateTime?          @default(dbgenerated("CURRENT_DATE")) @db.Date
  return_date       DateTime?          @db.Date
  status            String?            @default("Active") @db.VarChar(50)
  users             users?             @relation(fields: [allocated_by], references: [id], onUpdate: NoAction)
  assets            assets?            @relation(fields: [asset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employee_profiles employee_profiles? @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model asset_history {
  id         Int       @id @default(autoincrement())
  asset_id   Int?
  action     String    @db.VarChar(100)
  remarks    String?
  created_by Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  assets     assets?   @relation(fields: [asset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [created_by], references: [id], onUpdate: NoAction)
}

model assets {
  id                Int                 @id @default(autoincrement())
  asset_code        String              @unique @db.VarChar(50)
  asset_name        String              @db.VarChar(200)
  asset_type        String              @db.VarChar(100)
  purchase_date     DateTime?           @db.Date
  purchase_cost     Decimal?            @db.Decimal(12, 2)
  status            String?             @default("Available") @db.VarChar(50)
  asset_allocations asset_allocations[]
  asset_history     asset_history[]
}

model audit_logs {
  id           Int       @id @default(autoincrement())
  table_name   String    @db.VarChar(100)
  action_type  String    @db.VarChar(50)
  record_id    Int
  old_data     Json?
  new_data     Json?
  performed_by Int?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

model departments {
  id                Int                 @id @default(autoincrement())
  department_name   String              @unique @db.VarChar(100)
  employee_profiles employee_profiles[]
}

model employee_images {
  id                Int                @id @default(autoincrement())
  employee_id       Int?
  image_url         String
  file_type         String?            @db.VarChar(50)
  employee_profiles employee_profiles? @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model employee_profiles {
  id                 Int                  @id @default(autoincrement())
  user_id            Int?                 @unique
  department_id      Int?
  phone              String?              @db.VarChar(20)
  address            String?
  designation        String?              @db.VarChar(100)
  salary             Decimal?             @db.Decimal(10, 2)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  asset_allocations  asset_allocations[]
  employee_images    employee_images[]
  departments        departments?         @relation(fields: [department_id], references: [id], onUpdate: NoAction)
  users              users?               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employee_skills    employee_skills[]
  leave_applications leave_applications[]
  leave_balance      leave_balance[]
}

model employee_skills {
  id                Int                @id @default(autoincrement())
  employee_id       Int?
  skill_id          Int?
  employee_profiles employee_profiles? @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  skills            skills?            @relation(fields: [skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([employee_id, skill_id])
}

model leave_applications {
  id                Int                @id @default(autoincrement())
  employee_id       Int?
  leave_type_id     Int?
  from_date         DateTime           @db.Date
  to_date           DateTime           @db.Date
  total_days        Int
  reason            String?
  status            String?            @default("Pending") @db.VarChar(30)
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  approval_history  approval_history[]
  employee_profiles employee_profiles? @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  leave_types       leave_types?       @relation(fields: [leave_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model leave_balance {
  id                Int                @id @default(autoincrement())
  employee_id       Int?
  leave_type_id     Int?
  available_days    Int
  employee_profiles employee_profiles? @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  leave_types       leave_types?       @relation(fields: [leave_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([employee_id, leave_type_id])
}

model leave_types {
  id                 Int                  @id @default(autoincrement())
  leave_name         String               @unique @db.VarChar(100)
  total_days         Int
  leave_applications leave_applications[]
  leave_balance      leave_balance[]
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  title      String    @db.VarChar(200)
  message    String
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model password_reset {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  token      String   @db.VarChar(255)
  expires_at DateTime @db.Timestamp(6)
  users      users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model skills {
  id              Int               @id @default(autoincrement())
  skill_name      String            @unique @db.VarChar(100)
  employee_skills employee_skills[]
}

model users {
  id                 Int                 @id @default(autoincrement())
  name               String              @db.VarChar(100)
  email              String              @unique @db.VarChar(100)
  password           String              @db.VarChar(255)
  role               String?             @default("employee") @db.VarChar(20)
  verified           Boolean?            @default(false)
  verification_token String?             @db.VarChar(255)
  refresh_token      String?             @db.VarChar(255)
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  approval_history   approval_history[]
  asset_allocations  asset_allocations[]
  asset_history      asset_history[]
  employee_profiles  employee_profiles?
  notifications      notifications[]
  password_reset     password_reset[]
}

model employee_summary {
  employee_id     Int      @id
  name            String
  email           String
  role            String
  department_name String?
  designation     String?
  phone           String?
  salary          Decimal?
}

model leave_summary_view {
  leave_id      Int      @id
  employee_name String
  leave_name    String
  from_date     DateTime @db.Date
  to_date       DateTime @db.Date
  total_days    Int
  reason        String?
  status        String
  created_at    DateTime @db.Timestamp(6)
}

model asset_summary_view {
  asset_id          Int       @id
  asset_code        String
  asset_name        String
  asset_type        String
  asset_status      String
  allocated_to_name String?
  allocated_date    DateTime? @db.Date
  return_date       DateTime? @db.Date
}

